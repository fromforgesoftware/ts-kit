{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"composite": true,
		"declaration": true,
		"declarationMap": true,
		"inlineSources": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"types": ["reflect-metadata", "node"]
	},
	"exclude": ["src/**/*.spec.ts", "src/**/*.test.ts", "src/__tests__/**"],
	"include": ["src/**/*.ts"]
}
